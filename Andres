{"project":{"commands":[{"father":"trycatch","command":"","id":"4f4afc8a-8893-65b5-9d42-974927428031","group":"logic","mode_live":false,"children":[{"father":"execScriptPython","command":"import win32com.client\nimport pandas as pd\nfrom datetime import datetime\nimport pythoncom\n\ncompaneros = [  \n    \"marco.vallejo@alldora.com.mx\",\t\n    \"andres.hurtado@alldora.com.mx\",\n    \"griseilys.ordaz@alldora.com.mx\",\n    \"mauricio.zarazua@alldora.com.mx\",\n    \"victor.urbano@alldora.com.mx\",\n    \"gabriel.gonzalez@alldora.com.mx\",\n    \"juan.ortiz@alldora.com.mx\",\n    \"mauricio.rodriguez@alldora.com.mx\"\n]\n\nhoy = datetime.now()\nprimer_dia_mes_actual = hoy.replace(day=1, hour=0, minute=0, second=0, microsecond=0)\nfecha_fin = hoy.replace(hour=23, minute=59, second=59, microsecond=0)\n\n#  Formato correcto para Outlook Restrict(): MM/DD/YYYY HH:MM\ninicio_str = primer_dia_mes_actual.strftime(\"%d/%m/%Y %H:%M\")\nfin_str    = fecha_fin.strftime(\"%d/%m/%Y %H:%M\")\n\noutlook = win32com.client.Dispatch(\"Outlook.Application\").GetNamespace(\"MAPI\")\n\neventos = []\n\nfor alias in companeros:\n    try:\n        recipient = outlook.CreateRecipient(alias)\n        recipient.Resolve()\n\n        if not recipient.Resolved:\n            print(f\" No se pudo resolver: {alias}\")\n            continue\n\n        calendar = outlook.GetSharedDefaultFolder(recipient, 9)\n        items = calendar.Items\n        items.IncludeRecurrences = True\n        items.Sort(\"[Start]\")\n\n        #  Formato correcto del filtro\n        restriction = (\n            f\"[Start] >= '{inicio_str}' AND [Start] <= '{fin_str}'\"\n        )\n        filtered_items = items.Restrict(restriction)\n\n        count = 1\n        for item in filtered_items:\n            try:\n                if item.Class == 26:  # AppointmentItem\n                    start = item.Start\n                    end   = item.End\n                    duracion_horas = round((end - start).total_seconds() / 3600, 2)\n                    eventos.append({\n                        \"Hit\": count,\n                        \"Inicio\": start.strftime(\"%Y-%m-%d %H:%M\"),\n                        \"Fin\":   end.strftime(\"%Y-%m-%d %H:%M\"),\n                        \"Ubicación\": item.Location,\n                        \"Asunto\": item.Subject,\n                        \"Usuario\": recipient.Name,\n                        \"Duración (horas)\": duracion_horas,\n                        \"Categoría\": item.Categories\n                    })\n                    count += 1\n            except Exception as e:\n                print(f\"   Error al leer evento: {e}\")\n\n        print(f\" {recipient.Name}: {count} evento(s) encontrado(s).\")\n\n    except Exception as e:\n        print(f\" Error con {alias}: {str(e)}\")\n\nif eventos:\n    df = pd.DataFrame(eventos)\n    df.to_excel(r\"D:\\calendarios_compartidos.xlsx\", index=False, engine=\"openpyxl\")\n    print(\" Archivo 'calendarios_compartidos.xlsx' creado con éxito.\")\nelse:\n    print(\" No se encontraron eventos o no se pudo acceder a ningún calendario.\")","disabled":true,"index":0,"execute_debugg":0,"img":"","screenshot":"","line":"1.1","description":"Codigo python que saca la informacion del calendario desde el primer dia del mes al dia actual del mes","stop_onerror":false,"run_onerror":false,"stop_robot_onerror":false,"run_onerror_robot":"","run_when":"True","id":"ac858a09-5ff8-3d23-34db-5aed84cb1b8d","group":"scripts","mode_live":false,"children":[],"else":[],"execute":2,"message":"","time":"33.58748149871826","extra":[]},{"father":"execScriptPython","command":"def leer_excel(ruta: str):\n    import pandas as pd\n    import numpy as np\n\n    # 1. Lectura del archivo con el motor openpyxl\n    with pd.ExcelFile(ruta, engine=\"openpyxl\") as xls:\n        df = pd.read_excel(\n            xls,\n            usecols=\"A:H\",\n            header=0\n        )\n    \n    # 2. Reemplazo inicial de NaN de Pandas por un valor manejable\n    df = df.replace({np.nan: None})\n    \n    # Eliminamos filas que estén totalmente vacías en el Excel\n    df = df.dropna(how=\"all\").reset_index(drop=True)\n\n    # --- FASE DE LIMPIEZA PROFUNDA (Anti-Rotura de Ciclo) ---\n    for col in df.columns:\n        # Aplicamos la limpieza a todas las celdas para asegurar consistencia\n        df[col] = df[col].apply(lambda x: \n            \"\" if x is None or str(x).lower() == 'nan' or str(x).lower() == 'nat' # Convierte nulos a vacío\n            else str(x).replace('\\n', ' ')    # Quita saltos de línea\n                      .replace('\\r', ' ')    # Quita retornos de carro\n                      .replace('\"', \"'\")     # Cambia comilla doble por simple\n                      .strip()               # Quita espacios laterales\n        )\n\n    # 3. Conversión a la estructura de lista de diccionarios\n    salida_final = df.to_dict(orient=\"records\")\n    \n    return salida_final\n\n# --- EJECUCIÓN EN ROCKETBOT ---\nruta_archivo = r\"D:\\calendarios_compartidos.xlsx\"\nresultado = leer_excel(ruta_archivo)\n\n# Asignación a la variable que recorrerá el For Each\nSetVar(\"datosMacro\", resultado)","index":1,"execute_debugg":0,"img":"","screenshot":"","line":"1.2","description":"","stop_onerror":false,"run_onerror":false,"stop_robot_onerror":false,"run_onerror_robot":"","run_when":"True","id":"c108f10b-f367-935a-9203-1e3873f17a7e","group":"scripts","mode_live":false,"children":[],"else":[],"execute":2,"message":"","time":"0.027594566345214844","extra":[]},{"father":"setVar","command":"[]","stop_onerror":false,"run_onerror":false,"stop_robot_onerror":false,"run_onerror_robot":"","run_when":"True","id":"21ec910a-6fcf-9a95-32e2-d9e6e205f5ad","group":"system","mode_live":false,"var":"ListaDatosEscribir","children":[],"else":[],"line":"1.3","execute":2,"index":2,"execute_debugg":0,"img":"","message":"","screenshot":"","time":"0.002014636993408203","extra":[]},{"father":"setVar","command":"1","index":3,"execute_debugg