{"project":{"commands":[{"father":"trycatch","command":"","id":"4f4afc8a-8893-65b5-9d42-974927428031","group":"logic","mode_live":false,"children":[{"father":"execScriptPython","command":"import win32com.client\nimport pandas as pd\nfrom datetime import datetime, timedelta\n \n# Lista de correos o nombres como aparecen en Outlook (nombre visible o correo)\ncompaneros = [  \t\t\n  \t\t\"marco.vallejo@alldora.com.mx\",\t\n  \t\t\"andres.hurtado@alldora.com.mx\",\n  \t\t\"griseilys.ordaz@alldora.com.mx\",\n  \t\t\"mauricio.zarazua@alldora.com.mx\",\n  \t\t\"victor.urbano@alldora.com.mx\",\n  \t\t\"gabriel.gonzalez@alldora.com.mx\",\n  \t\t\"juan.ortiz@alldora.com.mx\",\n  \t\t\"mauricio.rodriguez@alldora.com.mx\"\n]\n \n# Rango de fechas: mes anterior completo\nhoy = datetime.now()\nprimer_dia_mes_actual = hoy.replace(day=1)\nfecha_actual = hoy\n\ninicio_str = primer_dia_mes_actual.strftime(\"%d/%m/%Y 00:00 000\")\nfin_str = fecha_actual.strftime(\"%d/%m/%Y 23:59 000\")\n \n# Conectar con Outlook\noutlook = win32com.client.Dispatch(\"Outlook.Application\").GetNamespace(\"MAPI\")\n \neventos = []\n \nfor alias in companeros:\n    try:\n        recipient = outlook.CreateRecipient(alias)\n        recipient.Resolve()\n        print(alias)\n        if recipient.Resolved:\n\n \n            # Obtener carpeta del calendario compartido\n            calendar = outlook.GetSharedDefaultFolder(recipient, 9)  # 9 = olFolderCalendar\n            items = calendar.Items\n            items.IncludeRecurrences = True\n            items.Sort(\"[Start]\")\n            # Filtrar eventos del mes anterior\n            restriction = f\"[Start] >= '{inicio_str}' AND [End] <= '{fin_str}'\"\n            filtered_items = items.Restrict(restriction)\n \t\t\t\n            Hit=0\n            for item in filtered_items:              \t\n                try:\n                    if item.Class == 26: # 26 = AppointmentItem                      \t\n                        start = item.Start\n                        end = item.End\n                        duracion_horas = round((end - start).total_seconds() / 3600, 2)\n                        eventos.append({\n                          \t\"Hit\":Hit,\n                            \"Inicio\": start.strftime(\"%Y-%m-%d %H:%M\"),\n                            \"Fin\": end.strftime(\"%Y-%m-%d %H:%M\"),\n                          \t\"Ubicación\": item.Location,\n                          \t\"Asunto\": item.Subject,\n                            \"Usuario\": recipient.Name,                          \n                            \"Duración (horas)\": duracion_horas,\n                          \t\"Categoría\": item.Categories\n                        })\n                    else:\n                        print(f\" Item omitido (no es cita válida) del calendario de {recipient.Name}.\")        \n                except Exception as e:\n                    print(f\" Error al leer evento: {e}\")\n        else:\n            print(f\" No se pudo resolver: {alias}  Verifica el nombre o alias en Outlook.\")\n        print(f\" Calendario de {recipient.Name} accedido correctamente.\")\n    except Exception as e:\n        print(f\" Error con {alias}: {str(e)}\")\n \n# Guardar resultados\nif eventos:\n    df = pd.DataFrame(eventos)\n    df.to_excel(\"D:\\calendarios_compartidos.xlsx\", index=False,engine=\"openpyxl\")\n    print(\" Archivo 'calendarios_compartidos.xlsx' creado con éxito.\")\nelse:\n    print(\" No se encontraron eventos o no se pudo acceder a ningún calendario.\")","disabled":false,"index":0,"execute_debugg":0,"img":"","screenshot":"","line":"1.1","description":"Codigo python que saca la informacion del calendario desde el primer dia del mes al dia actual del mes","stop_onerror":false,"run_onerror":false,"stop_robot_onerror":false,"run_onerror_robot":"","run_when":"True","id":"ac858a09-5ff8-3d23-34db-5aed84cb1b8d","group":"scripts","mode_live":false,"children":[],"else":[],"execute":2,"message":""},{"father":"module","comma